# Email backend settings
# Email backend settings
# For Mailgun:
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=postmaster@yourdomain.mailgun.org
# EMAIL_PASS=<mailgun-api-key-or-smtp-password>

# For Gmail (alternative):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=<gmail-app-password>

EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_SERVICE=
EMAIL_USER=maddierosemac@gmail.com
EMAIL_PASS=your-mailgun-password-or-api-key
EMAIL_FROM="Maddie Rose Studio <maddierosemac@gmail.com>"
SERVER_PORT=4000
ENQUIRIES_DB_PATH=

# Admin credentials for backend-only access
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-to-a-strong-password
ADMIN_API_KEY=change-to-a-strong-secret-token

# Restrict frontend origins when deployed
CORS_ORIGIN=https://your-production-domain.com

# Frontend API base URL (set this in Netlify if backend is hosted elsewhere)
VITE_API_BASE_URL=

# Optional: email address that receives studio/admin notifications
STUDIO_EMAIL=maddierosemac@gmail.com

# Optional: email address that receives studio/admin notifications
STUDIO_EMAIL=maddierosemac@gmail.com

# Notes:
# - For Gmail, create an App Password and set EMAIL_PASS accordingly.
# - Set EMAIL_SECURE=true if using SMTPS on port 465.
